    "lint": "eslint --ext .ts ."
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.2.0",
    "firebase-functions": "^5.0.0",
    "date-fns": "^3.6.0",
    "openai": "^4.52.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  },
  "private": true
}
