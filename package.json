{
  "name": "pocket-pal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "update": "eas update",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:e2e": "detox test",
    "functions:serve": "cd functions && npm run serve",
    "functions:deploy": "firebase deploy --only functions",
    "firebase:deploy": "firebase deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.2.2",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/analytics": "^21.7.3",
    "@react-native-firebase/app": "^21.7.3",
    "@react-native-firebase/auth": "^21.7.3",
    "@react-native-firebase/crashlytics": "^21.7.3",
    "@react-native-firebase/firestore": "^21.7.3",
    "@react-native-firebase/functions": "^21.7.3",
    "@react-native-firebase/messaging": "^21.7.3",
    "@react-native-firebase/perf": "^21.7.3",
    "@react-native-firebase/remote-config": "^21.7.3",
    "@shopify/flash-list": "2.3.1",
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/react-query": "^5.100.10",
    "date-fns": "^4.1.0",
    "expo": "^55.0.24",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.33",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.20",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "expo-task-manager": "~55.0.16",
    "expo-updates": "~55.0.22",
    "lottie-react-native": "~7.3.6",
    "moti": "^0.30.0",
    "nativewind": "^4.2.3",
    "react": "19.2.6",
    "react-hook-form": "^7.75.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-mmkv": "^3.2.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.0",
    "react-native-svg": "15.15.5",
    "react-native-view-shot": "4.0.3",
    "react-native-worklets": "0.8.3",
    "victory-native": "^41.20.3",
    "zod": "^3.24.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@testing-library/react-native": "^13.1.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "babel-jest": "^29.7.0",
    "eslint": "^9.27.0",
    "eslint-config-expo": "~55.0.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.17",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-test-renderer": "19.2.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|moti|@motify|victory-native)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/*.stories.{ts,tsx}"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-track-player",
        "@notifee/react-native",
        "react",
        "react-test-renderer"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": false
      }
    }
  }
}
